{% extends 'base.jinja' %}

{% block content %}
<div class="p-4 h-dvh flex flex-col gap-4 justify-center items-center">
    <div class="p-6 w-80 sm:w-120 rounded-xl shadow-md border flex flex-col gap-4 transition-colors duration-150"
        :class="isDark ? 'bg-neutral-800 border-neutral-700' : 'bg-white border-neutral-200'">

        <p class="text-4xl font-bold transition-colors duration-150"
            :class="isDark ? 'text-neutral-200' : 'text-black'">Reset Your Password</p>

        <p class="transition-colors duration-150 text-xl sm:text-base"
            :class="isDark ? 'text-neutral-500' : 'text-neutral-600'">
            Choose a strong password that you could remember
        </p>

        {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
        {% for category, message in messages %}
        <div
            class="p-3 rounded-md text-sm transition-colors duration-150
                            {% if category == 'success' %}bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800
                            {% elif category == 'error' %}bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800
                            {% elif category == 'warning' %}bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-800
                            {% else %}bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800{% endif %}">
            {{ message }}
        </div>
        {% endfor %}
        {% endif %}
        {% endwith %}

        <form method="POST" action="/reset-password?token={{ request.args.get('token') }}" class="flex flex-col gap-4 items-start w-full" id="resetForm" novalidate>
            <div class="w-full">
                <input placeholder="New Password" type="password" id="password1" name="password1"
                    class="shadow-md text-xl sm:text-base w-full border p-2 rounded-md focus:border-blue-400 outline-none transition duration-150"
                    :class="isDark ? 'bg-neutral-700 text-white placeholder-neutral-400 border-neutral-600' : 'bg-white text-black placeholder-gray-500 border-neutral-300'"
                    minlength="8" required />
                <div class="text-red-500 text-sm mt-1 hidden" id="password1Error">Password must be at least 8 characters
                </div>
            </div>

            <div class="w-full">
                <input placeholder="Confirm New Password" type="password" id="password2" name="password2"
                    class="shadow-md border w-full p-2 text-xl sm:text-base rounded-md focus:border-blue-400 outline-none transition duration-150"
                    :class="isDark ? 'bg-neutral-700 text-white placeholder-neutral-400 border-neutral-600' : 'bg-white text-black placeholder-gray-500 border-neutral-300'"
                    required minlength="8" />
                <div class="text-red-500 text-sm mt-1 hidden" id="password2Error">Passwords do not match</div>
            </div>

            <button type="submit"
                class="p-2 hover:opacity-90 active:opacity-80 transition duration-150 w-full text-white bg-orange-500 hover:bg-orange-600 rounded-md shadow-md cursor-pointer text-xl sm:text-base disabled:opacity-50 disabled:cursor-not-allowed"
                id="submitBtn">
                Reset Password
            </button>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('resetForm');
        const password1 = document.getElementById('password1');
        const password2 = document.getElementById('password2');
        const password1Error = document.getElementById('password1Error');
        const password2Error = document.getElementById('password2Error');
        const submitBtn = document.getElementById('submitBtn');

        function validatePassword() {
            const p1 = password1.value;
            const p2 = password2.value;
            let isValid = true;

            if (p1.length < 8 && p1.length > 0) {
                password1Error.classList.remove('hidden');
                isValid = false;
            } else {
                password1Error.classList.add('hidden');
            }

            if (p2.length > 0 && p1 !== p2) {
                password2Error.classList.remove('hidden');
                isValid = false;
            } else {
                password2Error.classList.add('hidden');
            }

            submitBtn.disabled = !isValid || p1.length === 0 || p2.length === 0;
        }

        form.addEventListener('submit', function (e) {
            const p1 = password1.value;
            const p2 = password2.value;

            if (p1.length < 8) {
                e.preventDefault();
                password1Error.classList.remove('hidden');
                password1.focus();
                return;
            }

            if (p1 !== p2) {
                e.preventDefault();
                password2Error.classList.remove('hidden');
                password2.focus();
                return;
            }
        });

        password1.addEventListener('input', validatePassword);
        password2.addEventListener('input', validatePassword);

        validatePassword();
    });
</script>
{% endblock %}