{% extends "base.jinja" %}

{% block content %}
    <div class="p-4 h-dvh flex flex-col gap-4 justify-center items-center">
        <div class="p-6 w-80 sm:w-120 rounded-xl shadow-md border flex flex-col gap-4 transition-colors duration-150"
             :class="isDark ? 'bg-neutral-800 border-neutral-700' : 'bg-white border-neutral-200'">
            
            <p class="text-4xl font-bold transition-colors duration-150"
               :class="isDark ? 'text-neutral-200' : 'text-black'">Log In</p>
            
            <p class="transition-colors duration-150 text-xl sm:text-base"
               :class="isDark ? 'text-neutral-500' : 'text-neutral-600'">
                New User? 
                <a class="font-bold text-orange-600 border-b-2 border-dotted hover:opacity-80  transition" href="/register">Register</a>
            </p>

            {% with messages = get_flashed_messages(with_categories=true) %}
                {% if messages %}
                    {% for category, message in messages %}
                        <div class="p-3 rounded-md text-sm transition-colors duration-150
                            {% if category == 'success' %}bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800
                            {% elif category == 'error' %}bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800
                            {% elif category == 'warning' %}bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-800
                            {% else %}bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800{% endif %}">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endif %}
            {% endwith %}
            
            <form method="POST" action="/login" class="flex flex-col gap-4 items-start w-full" id="loginForm" novalidate>
                <input 
                    placeholder="E-mail" 
                    type="email" 
                    id="email"
                    name="email"
                    class="shadow-md text-xl sm:text-base w-full border p-2 rounded-md focus:border-blue-400 outline-none transition duration-150"
                    :class="isDark ? 'bg-neutral-700 text-white placeholder-neutral-400 border-neutral-600' : 'bg-white text-black placeholder-gray-500 border-neutral-300'"
                    required
                    pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
                />
                <div class="text-red-500 text-sm hidden" id="emailError">Please enter a valid email address</div>
                
                <input 
                    placeholder="Password" 
                    type="password" 
                    id="password"
                    name="password"
                    class="shadow-md border w-full p-2 text-xl sm:text-base rounded-md focus:border-blue-400 outline-none transition duration-150"
                    :class="isDark ? 'bg-neutral-700 text-white placeholder-neutral-400 border-neutral-600' : 'bg-white text-black placeholder-gray-500 border-neutral-300'"
                    required
                    minlength="1"
                />
                <div class="text-red-500 text-sm hidden" id="passwordError">Password is required</div>
                
                <a class="transition-colors duration-150 hover:opacity-80 text-xl sm:text-base"
                   :class="isDark ? 'text-neutral-400' : 'text-neutral-600'"
                   href="/forgot-password">Forgot Password?</a>

                <button type="submit" class="p-2 hover:opacity-90 active:opacity-80 transition duration-150 w-full text-white bg-orange-500 hover:bg-orange-600 rounded-md shadow-md cursor-pointer text-xl sm:text-base">Log In</button>
            </form>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('loginForm');
            const email = document.getElementById('email');
            const password = document.getElementById('password');
            
            const emailError = document.getElementById('emailError');
            const passwordError = document.getElementById('passwordError');
            
            email.addEventListener('input', function() {
                if (this.validity.valid) {
                    emailError.classList.add('hidden');
                    this.classList.remove('border-red-500');
                } else {
                    emailError.classList.remove('hidden');
                    this.classList.add('border-red-500');
                }
            });
            
            password.addEventListener('input', function() {
                if (this.value.trim().length > 0) {
                    passwordError.classList.add('hidden');
                    this.classList.remove('border-red-500');
                } else {
                    passwordError.classList.remove('hidden');
                    this.classList.add('border-red-500');
                }
            });
            
            form.addEventListener('submit', function(e) {
                let isValid = true;
                
                if (!email.validity.valid) {
                    emailError.classList.remove('hidden');
                    email.classList.add('border-red-500');
                    isValid = false;
                }
                
                if (password.value.trim().length === 0) {
                    passwordError.classList.remove('hidden');
                    password.classList.add('border-red-500');
                    isValid = false;
                }
                
                if (!isValid) {
                    e.preventDefault();
                }
            });
        });
    </script>
{% endblock %}