{% extends "base.jinja" %}

{% block content %}
    <div class="p-4 h-dvh flex flex-col gap-4 justify-center items-center">

        <div class="bg-white p-6 w-120 rounded-xl shadow-md border border-neutral-200 flex flex-col gap-4">
            <p class="text-4xl font-bold">Log In</p>
            <p class="text-neutral-600">New User? <a class="font-bold text-orange-600 border-b-2 border-dotted" href="/register">Register</a></p>
            <form method="POST" action="/login" class="flex flex-col gap-4 items-start" id="loginForm" novalidate>
                <input 
                    placeholder="E-mail" 
                    type="email" 
                    id="email"
                    name="email"
                    class="shadow-md w-full border focus:border-blue-400 outline-none transition duration-150 p-2 rounded-md border-neutral-300"
                    required
                    pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
                />
                <div class="text-red-500 text-sm hidden" id="emailError">Please enter a valid email address</div>
                
                <input 
                    placeholder="Password" 
                    type="password" 
                    id="password"
                    name="password"
                    class="shadow-md border w-full p-2 rounded-md focus:border-blue-400 outline-none transition duration-150 border-neutral-300"
                    required
                    minlength="1"
                />
                <div class="text-red-500 text-sm hidden" id="passwordError">Password is required</div>
                
                <a class="text-neutral-600" href="/forgot-password">Forgot Password?</a>

                <button type="submit" class="p-2 hover:opacity-90 active:opacity-80 transition duration-150 w-full  text-white  bg-orange-500 rounded-md shadow-md cursor-pointer">Log In</button>
            </form>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('loginForm');
            const email = document.getElementById('email');
            const password = document.getElementById('password');
            
            const emailError = document.getElementById('emailError');
            const passwordError = document.getElementById('passwordError');
            
            email.addEventListener('input', function() {
                if (this.validity.valid) {
                    emailError.classList.add('hidden');
                    this.classList.remove('border-red-500');
                } else {
                    emailError.classList.remove('hidden');
                    this.classList.add('border-red-500');
                }
            });
            
            password.addEventListener('input', function() {
                if (this.value.trim().length > 0) {
                    passwordError.classList.add('hidden');
                    this.classList.remove('border-red-500');
                } else {
                    passwordError.classList.remove('hidden');
                    this.classList.add('border-red-500');
                }
            });
            
            form.addEventListener('submit', function(e) {
                let isValid = true;
                
                if (!email.validity.valid) {
                    emailError.classList.remove('hidden');
                    email.classList.add('border-red-500');
                    isValid = false;
                }
                
                if (password.value.trim().length === 0) {
                    passwordError.classList.remove('hidden');
                    password.classList.add('border-red-500');
                    isValid = false;
                }
                
                if (!isValid) {
                    e.preventDefault();
                }
            });
        });
    </script>
{% endblock %}