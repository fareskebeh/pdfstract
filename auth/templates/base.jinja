<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            text-rendering: optimizeLegibility;
        }
    </style>

    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <title>PDFstract</title>
</head>
<body x-data="{ isDark: localStorage.getItem('theme') === 'dark', isAuthenticated: {{ is_authenticated | tojson }}}" 
      :class="isDark ? 'bg-[#101010]' : 'bg-neutral-100'"
      class="transition-colors duration-150">
    
    <nav class="p-4 fixed top-0 left-0 right-0 gap-8 flex justify-between z-50 border-b transition-colors duration-150"
         :class="isDark ? 'bg-neutral-950 border-b-neutral-800' : 'bg-white border-b-neutral-200'">
        
        <div class="flex gap-12">
            <a href="/" class="font-black tracking-tight text-xl transition-colors duration-150"
               :class="isDark ? 'text-white' : 'text-black'">
                pdf<span class="text-orange-600">stract</span>
            </a>

            <div class="flex items-center gap-12">
                <a href="/docs" class="transition-colors duration-150"
                   :class="isDark ? 'text-neutral-200' : 'text-neutral-800'">Docs</a>
                <a href="/pricing" class="transition-colors duration-150"
                   :class="isDark ? 'text-neutral-200' : 'text-neutral-800'">Pricing</a>
                
            </div>
        </div>

        <div class="flex items-center gap-4">
            <div class="space-x-2" :class="isAuthenticated ? 'hidden' : ''">
                <a href="/register" class="bg-orange-600 text-white p-2 rounded-lg shadow-md hover:opacity-90 transition duration-150">Get Started</a>
                <span class="transition-colors duration-150"
                      :class="isDark ? 'text-neutral-400' : 'text-neutral-600'">or</span>
                <a href="/login" class="text-orange-600 hover:opacity-80 transition duration-150">Log In</a>
            </div>
            <a class="priv_link border p-1 rounded-md transition-colors duration-150 shadow-md" href="/dashboard"
                   :class="isDark ? 'text-neutral-400 bg-neutral-900 border-neutral-800' : 'text-neutral-500 border-neutral-400 bg-neutral-50'">Dashboard</a>
            <i class="fas w-4 cursor-pointer hover:opacity-70 transition-colors duration-150"
               :class="isDark ? 'fa-moon text-white' : 'fa-sun text-neutral-500'"
               @click="isDark = !isDark; localStorage.setItem('theme', isDark ? 'dark' : 'light')">
            </i>
        </div>
    </nav>
    
    <main>
        {% block content %}{% endblock %}
    </main>
    {% if request.path == "/home" %}
        {% include 'footer.jinja' %}
    {% endif %}

    <script>
        const isAuthenticated = "{{ is_authenticated }}" === "True";
        const privLinks = document.querySelectorAll(".priv_link");
        
        privLinks.forEach(link => {
            isAuthenticated ? link.classList.remove("hidden") : link.classList.add("hidden");
        });
    </script>
</body>
</html>