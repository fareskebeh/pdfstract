{% extends 'base.jinja' %}

{% block content %}
<div class="pt-24 flex items-center justify-center h-dvh" x-data="keyDisplay()">
    <div class="p-8 rounded-2xl border flex flex-col items-start gap-2 transition-colors duration-150" :class="isDark ? 'border-neutral-600 bg-neutral-800' : 'border-neutral-300 bg-white'">
        <p class="text-3xl font-bold transition-colors duration-150" :class="isDark ? 'text-neutral-200' : 'text-neutral-800'">Here is your Brand New API Key</p>
        <p class="text-xl transition-colors duration-150" :class="isDark ? 'text-neutral-400' : 'text-neutral-500'">Copy it and store it somewhere safe, <u>This will NOT be shown again</u></p>

        <div class="w-full p-4 flex flex-col gap-2">
        <div class=" w-full flex gap-3 justify-between">
            <input :type="showKey ? 'text' : 'password'" class="font-mono rounded-md p-3 border transition-colors duration-150 flex-1 cursor-default" disabled :class="isDark ? 'bg-neutral-700/50 border-neutral-600 text-neutral-200' : 'bg-neutral-100 border-neutral-300 text-neutral-800'" value="{{raw}}">
            <div class="space-x-2 flex items-center">
                <button @click="toggleKey()" class="cursor-pointer p-3 rounded-lg transition-colors duration-150" :class="isDark ? 'hover:bg-neutral-700 text-neutral-400' : 'hover:bg-neutral-200 text-neutral-600'">
                    <i class="fas" :class="showKey ? 'fa-eye' : 'fa-eye-slash'"></i>
                </button>
                <button @click="copyToClipboard()" class="cursor-pointer p-3 rounded-lg transition-colors duration-150" :class="isDark ? 'hover:bg-neutral-700 text-neutral-400' : 'hover:bg-neutral-200 text-neutral-600'">
                    <i class="fas fa-copy"></i>
                </button>
            </div>
        </div>
        <p class="transition-colors *:transition-colors duration-150" :class="isDark ? 'text-neutral-400' : 'text-neutral-500'">key name: <strong :class="isDark ? 'text-neutral-200' : 'text-neutral-800'">{{name}}</strong></p>
        </div>
        <a href="/dashboard" class="text-white text-center p-2 rounded-lg shadow-sm w-full text-lg transition-colors duration-150 bg-orange-600 hover:bg-orange-700"><i class="fas fa-arrow-left"></i> Back to keys</a>
    </div>

    <div x-show="showToast" 
         x-transition:enter.duration.300ms 
         x-transition:leave.duration.300ms
         class="fixed bottom-8 left-1/2 transform -translate-x-1/2 px-6 py-3 rounded-lg shadow-lg transition-colors duration-150"
         :class="isDark ? 'bg-neutral-800 border border-neutral-600 text-neutral-200' : 'bg-white border border-neutral-300 text-neutral-800'">
        <i class="fas fa-check-circle text-green-500 mr-2"></i>
        Copied to clipboard!
    </div>
</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('keyDisplay', () => ({
        showKey: false,
        showToast: false,
        raw: '{{ raw }}',
        
        toggleKey() {
            this.showKey = !this.showKey;
        },
        
        copyToClipboard() {
            navigator.clipboard.writeText(this.raw).then(() => {
                this.showToast = true;
                setTimeout(() => {
                    this.showToast = false;
                }, 2000);
            }).catch(() => {
                const textarea = document.createElement('textarea');
                textarea.value = this.raw;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);
                this.showToast = true;
                setTimeout(() => {
                    this.showToast = false;
                }, 2000);
            });
        }
    }));
});
</script>
{% endblock %}