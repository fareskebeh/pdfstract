{% extends "base.jinja" %}

{% block content %}

<style>
    /*
Source - https://stackoverflow.com/a/26148146
Posted by PRB, modified by community. See post 'Timeline' for change history
Retrieved 2026-07-06, License - CC BY-SA 4.0
*/

    .fire {
        animation: burn 1.5s linear infinite alternate;
    }

    @keyframes burn {
        from {
            box-shadow: -.1em 0 .3em #fefcc9, .1em -.1em .3em #feec85, -.2em -.2em .4em #ffae34, .2em -.3em .3em #ec760c, -.2em -.4em .4em #cd4606, .1em -.5em .7em #973716, .1em -.7em .7em #451b0e;
        }

        45% {
            box-shadow: .1em -.2em .5em #fefcc9, .15em 0 .4em #feec85, -.1em -.25em .5em #ffae34, .15em -.45em .5em #ec760c, -.1em -.5em .6em #cd4606, 0 -.8em .6em #973716, .2em -1em .8em #451b0e;
        }

        70% {
            box-shadow: -.1em 0 .3em #fefcc9, .1em -.1em .3em #feec85, -.2em -.2em .6em #ffae34, .2em -.3em .4em #ec760c, -.2em -.4em .7em #cd4606, .1em -.5em .7em #973716, .1em -.7em .9em #451b0e;
        }

        to {
            box-shadow: -.1em -.2em .6em #fefcc9, -.15em 0 .6em #feec85, .1em -.25em .6em #ffae34, -.15em -.45em .5em #ec760c, .1em -.5em .6em #cd4606, 0 -.8em .6em #973716, -.2em -1em .8em #451b0e;
        }
    }
</style>

<div class="pt-24 p-8 max-w-7xl mx-auto">
    <div class="text-center ">
        <p class="text-4xl font-black transition-colors duration-150"
            :class="isDark ? 'text-white' : 'text-neutral-800'">
            PDFstract Pricing
        </p>
        <p class="mt-3 text-xl transition-colors duration-150"
            :class="isDark ? 'text-neutral-300' : 'text-neutral-600'">
            Pick a plan that suits the needs of your app the most.
        </p>

    </div>

    <div class="w-full p-8 gap-8 flex flex-col md:flex-row">
        {% for plan in plans %}
        {% set is_free = plan.price_cents == 0 %}
        {% set is_popular = loop.index == 2 %}
        {% set is_enterprise = loop.last %}

        <div class="relative flex-1 transition **:transition-colors **:duration-150 duration-150 shadow-lg border space-y-4 p-6 rounded-xl 
                        hover:shadow-2xl hover:-translate-y-1
                        {% if is_free %}shadow-green-500/20 hover:shadow-green-500/30{% endif %}
                        {% if is_enterprise %}fire{% endif %}
                        {% if is_popular %}border-indigo-600{% endif %}"
            :class="isDark ? 'border-neutral-700 bg-neutral-800' : 'border-neutral-300 bg-white'">

            {% if is_popular %}
            <div
                class="absolute -top-3 right-5 text-xs font-bold uppercase tracking-widest px-4 py-1 rounded-full bg-indigo-500 text-white">
                Popular choice
            </div>
            {% endif %}

            <p :class="isDark ? 'text-neutral-200' : 'text-neutral-800'" class="text-3xl font-bold">
                {{ plan.name }}
            </p>

            <div class="flex items-baseline gap-2">
                <p :class="isDark ? 'bg-green-800/30 text-green-300' : 'bg-green-200 text-green-800'"
                    class="text-3xl px-3 py-1 rounded-2xl inline-block font-bold">
                    {% if is_free %}
                    Free
                    {% else %}
                    ${{ "%.2f"|format(plan.price_cents/100) }}
                    {% endif %}
                </p>
                {% if not is_free %}
                <span :class="isDark ? 'text-neutral-400' : 'text-neutral-500'" class="text-sm">
                    /month
                </span>
                {% endif %}
            </div>

            <div class="space-y-2">
                {% for feat in plan.features %}
                <p :class="isDark ? 'text-neutral-400' : 'text-neutral-700'" class="flex items-start gap-2">
                    <span class="text-green-500 mt-1">✓</span>
                    <span>{{ feat }}</span>
                </p>
                {% endfor %}
            </div>

            <div class="pt-4">
                {% if is_free %}
                <a href="/register"
                    class="block w-full text-center font-bold px-6 py-3 rounded-xl transition-all duration-150 hover:-translate-y-0.5 bg-green-500 hover:bg-green-600 hover:shadow-lg hover:shadow-green-500/30 text-white">
                    Experiment with the Free Tier
                </a>
                <p class="text-xs text-center mt-2 opacity-70"
                    :class="isDark ? 'text-neutral-400' : 'text-neutral-500'">
                    No credit card required.
                </p>
                {% elif is_enterprise %}
                <a href="/register"
                    class="block w-full text-center font-bold px-6 py-3 rounded-xl transition-all duration-150 hover:-translate-y-0.5 bg-orange-600 hover:bg-orange-700 hover:shadow-lg hover:shadow-orange-500/30 text-white">
                    Unlock PRO
                </a>
                {% else %}
                <a href="/register"
                    class="block w-full text-center font-bold px-6 py-3 rounded-xl transition-all duration-150 hover:-translate-y-0.5 bg-indigo-500 hover:bg-indigo-600 hover:shadow-lg hover:shadow-indigo-600/30 text-white">
                    Upgrade Now
                </a>
                
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- Personal Bottom Banner -->
    <div class="mt-12 text-center transition-colors duration-150"
        :class="isDark ? 'text-neutral-400' : 'text-neutral-500'">
        <p class="text-sm space-y-2">
            <span class="block">👋 I'm the developer. If you hit any issues, email me directly.</span>
            <span class="block text-xs opacity-60">
                Already 4,000+ developers using PDFstract • Free plan covers 100 pages/month
            </span>
        </p>
    </div>
</div>
{% endblock %}