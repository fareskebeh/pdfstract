{% extends "base.jinja" %}

{% block content %}
    <div class="flex *:flex-1 **:transition-colors **:duration-150">
        <div :class="isDark ? 'text-white border-neutral-800' : 'text-neutral-800 border-neutral-300' " class="border-r p-8 pt-24 space-y-2">
            <p class="font-black text-3xl">Manage Your API Keys</p>
            <p :class="isDark ? 'text-neutral-400' : 'text-neutral-600'" class="text-xl">{{ email }}</p>
        </div>

        <div class=" pt-24 p-8" :class="isDark ? 'text-white' : 'text-neutral-800' ">
            <p class="font-black text-3xl">Monitor Usage</p>
        </div>
        
    </div>
{% endblock %}