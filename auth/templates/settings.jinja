{% extends "base.jinja" %}

{% block content %}
    <div class="p-4 h-dvh flex flex-col gap-4 justify-center items-center">
        <div class="p-6 w-80 h-[70%] sm:w-120 rounded-xl overflow-y-auto shadow-md border flex flex-col gap-4 transition-colors duration-150"
             :class="isDark ? 'bg-neutral-800 border-neutral-700' : 'bg-white border-neutral-200'">
            
            <p class="text-4xl font-bold transition-colors duration-150"
               :class="isDark ? 'text-neutral-200' : 'text-black'">Settings</p>
            
            
            <div class="flex flex-col gap-4 items-start w-full">
                
                <form action="/settings" id="prefsForm" method="POST" class="w-full border-b p-2 mb-2 flex flex-col transition duration-150 gap-4 items-start w-full" :class="isDark ? 'border-b-neutral-700' : 'border-b-neutral-200'">
                    <p class="font-bold text-2xl" :class="isDark ? 'text-white' : 'text-black'">Preferences</p>
                    <div class="flex justify-between w-full items-center">
                        <div :class="isDark ? 'text-neutral-300' : 'text-neutral-700'" class="flex p-2 gap-4 items-center">
                            <i class="fas fa-language"></i>
                            <p>Preferred Language</p>
                        </div>

                        <div>
                            <select name="lang_pref" id="languageChoice" class="cursor-pointer" :class="isDark ? 'text-neutral-500' : 'text-neutral-600'">
                                <option value="en" {% if preferred_language == 'en' %}selected{% endif %}>English</option>
                                <option value="es" {% if preferred_language == 'es' %}selected{% endif %}>Español</option>
                                <option value="fr" {% if preferred_language == 'fr' %}selected{% endif %}>Français</option>
                                <option value="zh" {% if preferred_language == 'zh' %}selected{% endif %}>中文 (简体)</option>
                                <option value="ru" {% if preferred_language == 'ru' %}selected{% endif %}>Русский</option>
                                <option value="ar" {% if preferred_language == 'ar' %}selected{% endif %}>العربية</option>
                            </select>
                        </div>
                    </div>

                    <div class="h-px transition duration-150 w-full" :class='isDark ? "bg-neutral-700" : "bg-neutral-200"'></div>
    
                    <div class="flex justify-between w-full items-center">
                        <div :class="isDark ? 'text-neutral-300' : 'text-neutral-700'" class="flex p-2 gap-4 items-center">
                            <i class="fas fa-sun"></i>
                            <p>Theme</p>
                        </div>

                        <div>
                            <select name="theme_pref" id="themeChoice" class="cursor-pointer w-20" :class="isDark ? 'text-neutral-500' : 'text-neutral-600'">
                                <option value="dark" {% if preferred_theme == 'dark' %}selected{% endif %}>Dark</option>
                                <option value="light" {% if preferred_theme == 'light' %}selected{% endif %}>Light</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex items-center p-2 w-full">
                        <button type="submit" id="submitButton" class="ml-auto disabled:opacity-60 disabled:cursor-not-allowed hover:opacity-90 active:opacity-80 transition duration-150 p-2 bg-orange-600 px-4 rounded-xl shadow-sm cursor-pointer">
                            Apply
                        </button>
                    </div>
                </form>

                <p class="font-bold text-2xl" :class="isDark ? 'text-white' : 'text-black'">Account</p>


                
                <div class="flex justify-between w-full items-center">
                    <div class="flex p-2 gap-4 items-center" :class="isDark ? 'text-neutral-300' : 'text-neutral-700'">
                        <i class="fas fa-key"></i>
                        <p>Change Password</p>
                    </div>

                </div>
                
                <div class="h-px transition duration-150 w-full" :class='isDark ? "bg-neutral-700" : "bg-neutral-200"'></div>

                <div class="flex justify-between w-full items-center">
                    <div class="flex p-2 gap-4 items-center">
                        <i class="text-red-500 fas fa-trash"></i>
                        <p class="text-red-500">Delete Account</p>
                    </div>

                </div>

                <div class="h-px transition duration-150 w-full" :class='isDark ? "bg-neutral-700" : "bg-neutral-200"'></div>

                <a href="/logout" class="flex justify-between w-full hover:bg-red-500/10 rounded-xl transition duration-150 items-center">
                    <div class="flex p-2 gap-4 items-center">
                        <i class="text-red-500 fas fa-sign-out-alt"></i>
                        <p class="text-red-500">Log out</p>
                    </div>

                </a>

                <div class="text-red-500 text-sm hidden" id="passwordError">Password is required</div>
                {% with messages = get_flashed_messages(with_categories=true) %}
                    {% if messages %}
                        {% for category, message in messages %}
                            <div class="text-sm transition-colors duration-150
                                {% if category == 'success' %} text-green-500  
                                {% elif category == 'error' %} text-red-500  
                                {% elif category == 'warning' %} text-yellow-700  
                                {% else %}bg-blue-100 dark:bg-blue-900/30 text-blue-700  {% endif %}">
                                {{ message }}
                            </div>
                        {% endfor %}
                    {% endif %}
                {% endwith %}
                
            </div>
        </div>
    </div>

    <script>
        console.log("{{ preferred_language }}")
        console.log("{{ theme }}")

        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('prefsForm');
            const lang = document.getElementById('languageChoice');
            const theme = document.getElementById('themeChoice');
            const submitButton = document.getElementById('submitButton');
            let isChanged=false;
            submitButton.disabled = true;
            function checkChanges() {
                const langChanged = lang.value !== "{{ preferred_language }}";
                const themeChanged = theme.value !== "{{ theme }}";
                
                isChanged = langChanged || themeChanged;
                submitButton.disabled = !isChanged;
            }

            lang.addEventListener('change', checkChanges);
            theme.addEventListener('change', checkChanges);
            
            form.addEventListener('submit', function(e) {                
                
                if (!isChanged) {
                    e.preventDefault();
                    return;
                }
            });
        });
    </script>
{% endblock %}