{% extends "base.jinja" %}

{% block content %}
    <div class="p-4 h-dvh flex flex-col gap-4 justify-center items-center">
        <div class="p-6 w-80 sm:w-120 rounded-xl shadow-md border flex flex-col gap-4 transition-colors duration-150"
             :class="isDark ? 'bg-neutral-800 border-neutral-700' : 'bg-white border-neutral-200'">
            
            <p class="text-4xl font-bold transition-colors duration-150"
               :class="isDark ? 'text-neutral-200' : 'text-black'">Register</p>
            
            <p class="transition-colors duration-150 text-lg sm:text-base"
               :class="isDark ? 'text-neutral-500' : 'text-neutral-600'">
                Already a user? 
                <a class="font-bold text-orange-600 border-b-2 border-dotted hover:opacity-80 transition" href="/login">Log in</a>
            </p>
            
            <form method="POST" action="/register" class="flex flex-col gap-4 items-start w-full" id="registerForm" novalidate>
                <input 
                    placeholder="E-mail" 
                    type="email" 
                    id="email"
                    name="email"
                    class="shadow-md w-full border p-2 rounded-md focus:border-blue-400 outline-none transition duration-150 text-xl sm:text-base"
                    :class="isDark ? 'bg-neutral-700 text-white placeholder-neutral-400 border-neutral-600' : 'bg-white text-black placeholder-gray-500 border-neutral-300'"
                    required
                    pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
                />
                <div class="text-red-500 text-sm hidden" id="emailError">Please enter a valid email address</div>
                
                <input 
                    placeholder="Password" 
                    type="password" 
                    id="password"
                    name="password"
                    class="shadow-md text-xl sm:text-base border w-full p-2 rounded-md focus:border-blue-400 outline-none transition duration-150"
                    :class="isDark ? 'bg-neutral-700 text-white placeholder-neutral-400 border-neutral-600' : 'bg-white text-black placeholder-gray-500 border-neutral-300'"
                    required
                    minlength="8"
                />
                <div class="text-red-500 text-sm hidden" id="passwordError">Password must be at least 8 characters</div>
                
                <input 
                    placeholder="Confirm Password" 
                    type="password" 
                    id="confirmPassword"
                    name="confirmPassword"
                    class="shadow-md border text-xl sm:text-base w-full p-2 rounded-md focus:border-blue-400 outline-none transition duration-150"
                    :class="isDark ? 'bg-neutral-700 text-white placeholder-neutral-400 border-neutral-600' : 'bg-white text-black placeholder-gray-500 border-neutral-300'"
                    required
                />
                <div class="text-red-500 text-sm hidden" id="confirmError">Passwords do not match</div>
                
                <button type="submit" class="text-xl sm:text-base p-2 hover:opacity-90 active:opacity-80 transition duration-150 w-full text-white bg-orange-600 hover:opacity-90 rounded-md shadow-md cursor-pointer">Register</button>
            </form>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('registerForm');
            const email = document.getElementById('email');
            const password = document.getElementById('password');
            const confirmPassword = document.getElementById('confirmPassword');
            
            const emailError = document.getElementById('emailError');
            const passwordError = document.getElementById('passwordError');
            const confirmError = document.getElementById('confirmError');
            
            email.addEventListener('input', function() {
                if (this.validity.valid) {
                    emailError.classList.add('hidden');
                    this.classList.remove('border-red-500');
                } else {
                    emailError.classList.remove('hidden');
                    this.classList.add('border-red-500');
                }
            });
            
            password.addEventListener('input', function() {
                if (this.value.length >= 8) {
                    passwordError.classList.add('hidden');
                    this.classList.remove('border-red-500');
                } else {
                    passwordError.classList.remove('hidden');
                    this.classList.add('border-red-500');
                }
                if (confirmPassword.value) {
                    validateConfirmPassword();
                }
            });
            
            confirmPassword.addEventListener('input', validateConfirmPassword);
            
            function validateConfirmPassword() {
                if (confirmPassword.value === password.value && confirmPassword.value !== '') {
                    confirmError.classList.add('hidden');
                    confirmPassword.classList.remove('border-red-500');
                } else {
                    confirmError.classList.remove('hidden');
                    confirmPassword.classList.add('border-red-500');
                }
            }
            
            form.addEventListener('submit', function(e) {
                let isValid = true;
                
                if (!email.validity.valid) {
                    emailError.classList.remove('hidden');
                    email.classList.add('border-red-500');
                    isValid = false;
                }
                
                if (password.value.length < 8) {
                    passwordError.classList.remove('hidden');
                    password.classList.add('border-red-500');
                    isValid = false;
                }
                
                if (confirmPassword.value !== password.value || confirmPassword.value === '') {
                    confirmError.classList.remove('hidden');
                    confirmPassword.classList.add('border-red-500');
                    isValid = false;
                }
                
                if (!isValid) {
                    e.preventDefault();
                }
            });
        });
    </script>
{% endblock %}